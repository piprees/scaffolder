meta {
  name: User Profile
  type: http
  seq: 2
}

get {
  url: {{baseUrl}}/api/user/profile
  body: none
  auth: none
}

tests {
  test("status should be 200", function () {
    expect(res.getStatus()).to.equal(200);
  });
  test("profile payload", function () {
    expect(res.getBody().role).to.equal("USER");
  });
}
