# --- --- --- ---
# Setup Options
# --- --- --- ---
# Project directory
# Required Variable: Local path to the project directory on your machine (used by setup scripts).
# You can pass this in by calling `./setup.sh ~/projects/test-setup-app`, or set it here as an environment variable:
PROJECT_DIR=~/projects/test-setup-app

# Environment variables for Kamal deploy and automation scripts.
# Default is `0` to print full ascii art in logs. Set to 1 to enable compact output mode with minimal logs.
SETUP_COMPACT_OUTPUT=0

# Set to true to skip actual deploy steps and just print planned actions.
# Default is `false`, but can be enabled for testing or CI validation of deploy scripts without making changes.
DRY_RUN=true

# Set to true to skip all interactive prompts and use existing resources or defaults.
# Enable this to only use values in this .env file and avoid any prompts, e.g. for CI or repeatable local testing.
# Default is `false` to allow users to enter missing details during setup.
NON_INTERACTIVE=false

# Set to true to automatically wipe existing droplet and DNS records on deploy.
# Default is `false` to prevent accidental data loss, but can be enabled for a fully hands-off experience.
WIPE_EXISTING=false


# --- --- --- ---
# Deployment Options
# --- --- --- ---
# Required Repository Secret: GitHub App client ID used by the backend auth flow.
# Find it in GitHub -> Settings -> Developer settings -> GitHub Apps -> your app.
# Add `http://127.0.0.1:8080/login/oauth2/code/github` as an authorized
# callback URL in your GitHub App settings for local testing, or
# `http://<your-production-domain>/login/oauth2/code/github` for production.
OAUTH_CLIENT_ID=

# Required Repository Secret: GitHub App client secret paired with OAUTH_CLIENT_ID.
# Find it in GitHub -> Settings -> Developer settings -> GitHub Apps -> your app.
OAUTH_CLIENT_SECRET=

# Required Repository Secret: Comma-separated GitHub usernames that should have admin access in the app.
# Find/set this from your GitHub org/repo user list, e.g; `inky,blinky,clyde,tony`
ADMIN_GITHUB_USERNAMES=

# Required Repository Secret: DigitalOcean API token used for droplet/DNS operations.
# Create it in DigitalOcean -> API -> Tokens/Keys.
DO_API_TOKEN=

# Required Variable: GHCR username for container image pushes.
# Usually your GitHub username (or org bot account username), e.g; `inky`
KAMAL_REGISTRY_USERNAME=

# Required Repository Secret: GHCR password/token used by Kamal for registry auth.
# Use a GitHub PAT with package scopes (or GITHUB_TOKEN in GitHub Actions).
KAMAL_REGISTRY_PASSWORD=

# Required Repository Secret: Postgres password used by Kamal accessories and deploy workflows.
# Generate a strong random value, e.g. with `openssl rand -base64 32`.
POSTGRES_PASSWORD=

# Optional Environment Secret: Custom app domain (enables TLS + clean preview URLs).
# Find/use a domain you control in your DNS provider (DigitalOcean DNS or registrar).
APP_HOSTNAME=


# --- --- --- ---
# Droplet details
# --- --- --- ---
# Optional Environment Secret: DigitalOcean droplet ID (used by teardown/automation).
# Find it via `doctl compute droplet list` or the DigitalOcean dashboard.
# If this or DROPLET_IP is not set, a new droplet will be auto-provisioned every time you run this script
#DROPLET_ID=

# Optional Environment Secret: Droplet public IPv4 address (leave blank to auto-provision).
# Find it via `doctl compute droplet list` or the DigitalOcean dashboard.
# If this or DROPLET_ID is not set, a new droplet will be auto-provisioned every time you run this script
#DROPLET_IP=

# Optional Environment Secret: Local SSH private key path used by setup.sh to load key contents and infer fingerprint.
# Example: ~/.ssh/id_ed25519
DROPLET_SSH_PRIVATE_KEY_PATH=

# Required Repository Secret: SSH private key contents used for provisioning and SSH access to droplets in CI.
# This should be the private key paired with the fingerprint above, but with newlines preserved in the value.
# In local dev, use the above DROPLET_SSH_PRIVATE_KEY_PATH instead.
# To get this, run `pbcopy < ~/.ssh/id_ed25519` on Mac, or `cat ~/.ssh/id_ed25519 | clip` on Windows, replacing with your key path as needed.
#DROPLET_SSH_PRIVATE_KEY=

# Required Repository Secret: SSH key fingerprint to use in combination with DROPLET_SSH_PRIVATE_KEY
# Find it with `doctl compute ssh-key list` or in DigitalOcean -> Settings -> Security.
#DROPLET_SSH_KEY_FINGERPRINT=6f:38:07:99:cb:8e:df:d7:c2:92:f2:7a:06:47:6d:bc

# Optional Variable: DigitalOcean droplet size slug for provisioning.
# List available values with `doctl compute size list`.
# Defaults to `s-1vcpu-1gb`
# DROPLET_SIZE=

# Optional Variable: Droplet tag used for IP discovery in CI/teardown.
# Find/set it in DigitalOcean tags or via `doctl compute droplet list --tag-name <tag>`.
# Defaults to `app-name-in-kebab-case`
# DROPLET_TAG=

# Optional Variable: DigitalOcean region slug.
# List available values with `doctl compute region list`.
# Defaults to `lon1`
# DROPLET_REGION=

# Optional Variable: DigitalOcean image slug.
# List available values with `doctl compute image list-distribution ubuntu`.
# defaults to `ubuntu-24-04-x64`
# DROPLET_IMAGE=
